# ============================================
# Environment Variables - Event-Driven Ticketing Platform
# Copy file này thành .env rồi điền giá trị
# Docker Compose tự động đọc file .env cùng thư mục
# ============================================

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379

# Kafka
KAFKA_PORT=9092
KAFKA_EXTERNAL_PORT=29092

# Zookeeper
ZOOKEEPER_PORT=2181

# Consul
CONSUL_PORT=8500

# Keycloak
KEYCLOAK_PORT=8180

# Elasticsearch
ELASTICSEARCH_PORT=9200

# Kibana
KIBANA_PORT=5601
